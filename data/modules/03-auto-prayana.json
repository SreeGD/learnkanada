          "pronunciation": "saar, MUN-de EL-li? NE-ra HOG-li",
          "english": "Sir, where ahead? Shall I go straight?"
        },
        {
          "type": "choice",
          "prompt": "Tell him to go straight and then turn left at the signal",
          "choices": [
            {
              "kannada": "Nera hogi, signal-alli edagade tirugi.",
              "script": "ನೇರ ಹೋಗಿ, ಸಿಗ್ನಲ್‌ನಲ್ಲಿ ಎಡಗಡೆ ತಿರುಗಿ.",
              "pronunciation": "NE-ra HO-gi, SIG-nal-al-li E-da-ga-de ti-RU-gi",
              "english": "Go straight, turn left at the signal.",
              "correct": true
            },
            {
              "kannada": "Illi nilisi, signal beda.",
              "script": "ಇಲ್ಲಿ ನಿಲ್ಲಿಸಿ, ಸಿಗ್ನಲ್ ಬೇಡ.",
              "pronunciation": "IL-li ni-LI-si, SIG-nal BEH-da",
              "english": "Stop here, no signal.",
              "correct": false,
              "hint": "You're not there yet — stopping now strands you. Guide him: 'nera hogi' then 'edagade tirugi'."
            },
            {
              "kannada": "Signal-alli balagade tirugi.",
              "script": "ಸಿಗ್ನಲ್‌ನಲ್ಲಿ ಬಲಗಡೆ ತಿರುಗಿ.",
              "pronunciation": "SIG-nal-al-li BA-la-ga-de ti-RU-gi",
              "english": "Turn right at the signal.",
              "correct": false,
              "hint": "That's the wrong way — 'balagade' is right. You want 'edagade' (left)."
            }
          ],
          "correctReaction": {
            "speaker": "Auto Driver",
            "speakerEmoji": "🧑🏾",
            "kannada": "Sari saar, edagade tirugtini.",
            "script": "ಸರಿ ಸಾರ್, ಎಡಗಡೆ ತಿರುಗ್ತೀನಿ.",
            "pronunciation": "SA-ri saar, E-da-ga-de ti-RUG-tee-ni",
            "english": "Okay sir, I'll turn left.",
            "correct": true
          },
          "wrongReaction": {
            "speaker": "Auto Driver",
            "speakerEmoji": "🧑🏾",
            "kannada": "Edagado balagado saar? Confuse aaytu.",
            "script": "ಎಡಗಡೋ ಬಲಗಡೋ ಸಾರ್? ಕನ್ಫ್ಯೂಸ್ ಆಯ್ತು.",
            "pronunciation": "E-da-ga-do BA-la-ga-do saar? kan-fyooz AAY-tu",
            "english": "Left or right sir? I got confused.",
            "correct": false
          },
          "vocab": [
            { "kannada": "munde", "script": "ಮುಂದೆ", "pronunciation": "MUN-de", "english": "ahead / in front / next" },
            { "kannada": "tirugi", "script": "ತಿರುಗಿ", "pronunciation": "ti-RU-gi", "english": "turn (polite)" },
            { "kannada": "edagade", "script": "ಎಡಗಡೆ", "pronunciation": "E-da-ga-de", "english": "left side" },
            { "kannada": "balagade", "script": "ಬಲಗಡೆ", "pronunciation": "BA-la-ga-de", "english": "right side" },
            { "kannada": "signal", "script": "ಸಿಗ್ನಲ್", "pronunciation": "SIG-nal", "english": "traffic signal" }
          ],
          "grammarTip": "'-alli' means 'at / in': 'signal-alli' = at the signal, 'mane-alli' = at home. It attaches straight onto the place word and is one of the most useful endings for directions."
        },
        {
          "type": "choice",
          "prompt": "The gate is just ahead — ask him to stop there",
          "choices": [
