    {
      "id": "ap-001",
      "title": "Hailing an Auto & the Meter",
      "scene": "You're standing on the roadside in Jayanagar. An empty auto slows down beside you. The driver leans out.",
      "steps": [
        {
          "type": "dialogue",
          "speaker": "Auto Driver",
          "speakerEmoji": "🧑🏾",
          "kannada": "Elli hogbeku saar?",
          "script": "ಎಲ್ಲಿ ಹೋಗ್ಬೇಕು ಸಾರ್?",
          "pronunciation": "EL-li HOG-beh-ku saar",
          "english": "Where do you want to go, sir?"
        },
        {
          "type": "choice",
          "prompt": "Tell him you want to go to Lalbagh, and to use the meter",
          "choices": [
            {
              "kannada": "Lalbagh-ge hogbeku. Meter haaki.",
              "script": "ಲಾಲ್‌ಬಾಗ್‌ಗೆ ಹೋಗ್ಬೇಕು. ಮೀಟರ್ ಹಾಕಿ.",
              "pronunciation": "laal-baag-ge HOG-beh-ku. MEE-tar HAA-ki",
              "english": "I need to go to Lalbagh. Put the meter on.",
              "correct": true
            },
            {
              "kannada": "Lalbagh-ge hogbeku. Meter beda.",
              "script": "ಲಾಲ್‌ಬಾಗ್‌ಗೆ ಹೋಗ್ಬೇಕು. ಮೀಟರ್ ಬೇಡ.",
              "pronunciation": "laal-baag-ge HOG-beh-ku. MEE-tar BEH-da",
              "english": "I need to go to Lalbagh. No meter.",
              "correct": false,
              "hint": "Saying 'meter beda' invites a fixed (often inflated) price. Insist on 'meter haaki' (put the meter)."
            },
            {
              "kannada": "Lalbagh elli ide?",
              "script": "ಲಾಲ್‌ಬಾಗ್ ಎಲ್ಲಿ ಇದೆ?",
              "pronunciation": "laal-baag EL-li i-de",
              "english": "Where is Lalbagh?",
              "correct": false,
              "hint": "You're asking HIM for directions! State your destination with '-ge' (to): 'Lalbagh-ge'."
            }
          ],
          "correctReaction": {
            "speaker": "Auto Driver",
            "speakerEmoji": "🧑🏾",
            "kannada": "Meter-ge bartira? Sari, kuteer saar.",
            "script": "ಮೀಟರ್‌ಗೆ ಬರ್ತೀರಾ? ಸರಿ, ಕೂತ್ಕೊಳ್ಳಿ ಸಾರ್.",
            "pronunciation": "MEE-tar-ge BAR-tee-ra? SA-ri, KOOT-kol-li saar",
            "english": "You'll come by meter? Okay, sit, sir."
          },
          "wrongReaction": {
            "speaker": "Auto Driver",
            "speakerEmoji": "🧑🏾",
            "kannada": "Lalbagh-aa? Nooru rupayi saar.",
            "script": "ಲಾಲ್‌ಬಾಗಾ? ನೂರು ರೂಪಾಯಿ ಸಾರ್.",
            "pronunciation": "laal-baag-aa? NOO-ru ru-PAA-yi saar",
            "english": "Lalbagh? A hundred rupees, sir.",
            "correct": false
          },
          "vocab": [
            { "kannada": "hogbeku", "script": "ಹೋಗ್ಬೇಕು", "pronunciation": "HOG-beh-ku", "english": "(I) have to go" },
            { "kannada": "meter haaki", "script": "ಮೀಟರ್ ಹಾಕಿ", "pronunciation": "MEE-tar HAA-ki", "english": "put the meter on" },
            { "kannada": "kutkolli", "script": "ಕೂತ್ಕೊಳ್ಳಿ", "pronunciation": "KOOT-kol-li", "english": "please sit / get in" },
            { "kannada": "-ge", "script": "-ಗೆ", "pronunciation": "ge", "english": "to (a place)" }
